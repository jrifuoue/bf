#!/usr/bin/env bash
# SPDX-License-Identifier: BSD-2-Clause

# Exit on any error
set -e

maindir="/workspaces/bf/tilck"
bdir="/workspaces/bf/tilck/build"
dest="/workspaces/bf/tilck/build/test_fatpart"
tc="/workspaces/bf/tilck/toolchain4"
host_arch="x86_64"
host_arch_dir_sys="/workspaces/bf/tilck/toolchain4/host/linux-x86_64/ubuntu-24.04"
mtools_ver="4.0.49"

mtoolsdir=$host_arch_dir_sys/mtools/$mtools_ver
mformat=$mtoolsdir/mformat
mlabel=$mtoolsdir/mlabel
mmd=$mtoolsdir/mmd
mcopy=$mtoolsdir/mcopy


# Always (re)create the file because fathack --truncate shrinks it, and
# mformat would then format the small file with the wrong geometry.
dd status=none if=/dev/zero of=$dest bs=1M count=35

# mformat options
# -d <N> ; num of FAT copies
# -F     ; force FAT32 to be used
# -c <N> ; sectors per cluster
# -t <N> ; cylinders
# -h <N> ; heads
# -s <N> ; sectors
$mformat -i $dest -d 1 -F -c 1 -t 70 -h 16 -s 63 ::
$mlabel -i $dest ::TILCK

rm -rf $bdir/test_sysroot
mkdir $bdir/test_sysroot
cp -r $maindir/tests/unit/test_sysroot $bdir/
cd $bdir/test_sysroot

# Create file with random data
dd if=/dev/urandom of=./bigfile bs=1 count=1048599 # 1 MB + 23 bytes

# first, create the directories
for f in $(find * -type d); do
   $mmd -i $dest $f
done

# then, copy all the files in sysroot
for f in $(find * -type f); do
   $mcopy -i $dest $f ::/$f
done
